generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Users & Auth ──────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  address   String   @unique @db.VarChar(42)
  nonce     String   @default(cuid())
  username  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  taskCompletions TaskCompletion[]
  questProgress   QuestProgress[]
  locks           Lock[]

  @@index([address])
}

// ── Quests ────────────────────────────────────────────────────────────────────

model Quest {
  id              String   @id @default(cuid())
  title           String
  description     String   @db.Text
  bannerUrl       String?
  projectName     String
  projectLogo     String?
  startDate       DateTime
  endDate         DateTime
  maxParticipants Int?
  totalPoints     Int      @default(0)
  featured        Boolean  @default(false)
  active          Boolean  @default(true)
  tags            String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tasks    QuestTask[]
  rewards  QuestReward[]
  progress QuestProgress[]

  @@index([active, featured])
}

model QuestTask {
  id          String  @id @default(cuid())
  questId     String
  type        String // follow_twitter | retweet | join_discord | swap | quiz | etc.
  title       String
  description String  @db.Text
  points      Int
  required    Boolean @default(false)
  link        String?
  minAmount   String?
  tokenSymbol String?
  metadata    Json? // quiz options, answers, etc.
  order       Int     @default(0)

  quest       Quest            @relation(fields: [questId], references: [id], onDelete: Cascade)
  completions TaskCompletion[]

  @@index([questId])
}

model QuestReward {
  id      String  @id @default(cuid())
  questId String
  type    String // token | nft | points | whitelist
  symbol  String?
  amount  String?
  label   String

  quest Quest @relation(fields: [questId], references: [id], onDelete: Cascade)
}

model QuestProgress {
  id           String    @id @default(cuid())
  userId       String
  questId      String
  pointsEarned Int       @default(0)
  completed    Boolean   @default(false)
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  quest Quest @relation(fields: [questId], references: [id])

  @@unique([userId, questId])
  @@index([questId, pointsEarned])
}

model TaskCompletion {
  id          String   @id @default(cuid())
  userId      String
  taskId      String
  completedAt DateTime @default(now())

  user User      @relation(fields: [userId], references: [id])
  task QuestTask @relation(fields: [taskId], references: [id])

  @@unique([userId, taskId])
}

// ── Quest Submissions (third-party, pending admin approval) ──────────────────

model QuestSubmission {
  id               String           @id @default(cuid())
  // Submitter
  submitterAddress String           @db.VarChar(42)
  // Payment
  paymentTxHash    String           @db.VarChar(66)
  paymentChainId   Int              @default(1)
  feePaid          String           @default("0.05") // ETH amount string
  // Quest data (stored as JSON until approved)
  title            String
  description      String           @db.Text
  projectName      String
  projectUrl       String?
  bannerUrl        String?
  startDate        DateTime
  endDate          DateTime
  tags             String[]
  tasksJson        Json // Array of task objects
  rewardsJson      Json // Array of reward objects
  // Admin workflow
  status           SubmissionStatus @default(PENDING)
  adminNote        String?          @db.Text
  reviewedBy       String?          @db.VarChar(42) // admin address
  reviewedAt       DateTime?
  // If approved, the created quest ID
  questId          String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([submitterAddress])
  @@index([status])
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

// ── Staking Pool Submissions (third-party) ────────────────────────────────────

model StakingSubmission {
  id                 String           @id @default(cuid())
  submitterAddress   String           @db.VarChar(42)
  // Payment
  paymentTxHash      String           @db.VarChar(66)
  paymentChainId     Int              @default(1)
  feePaid            String           @default("0.05")
  // Pool config
  tokenAddress       String           @db.VarChar(42)
  tokenSymbol        String
  tokenName          String
  tokenDecimals      Int              @default(18)
  rewardTokenAddress String           @db.VarChar(42)
  rewardTokenSymbol  String
  chainId            Int              @default(1)
  apy                Float
  lockDays           Int              @default(0)
  minStake           String           @default("0")
  maxStake           String?
  poolStartDate      DateTime
  poolEndDate        DateTime
  totalRewardBudget  String
  description        String           @db.Text
  projectName        String
  projectUrl         String?
  logoUrl            String?
  // Admin workflow
  status             SubmissionStatus @default(PENDING)
  adminNote          String?          @db.Text
  reviewedBy         String?          @db.VarChar(42)
  reviewedAt         DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([submitterAddress])
  @@index([status])
}

// ── Perps Market Submissions (third-party) ────────────────────────────────────

model PerpsSubmission {
  id                   String           @id @default(cuid())
  submitterAddress     String           @db.VarChar(42)
  // Payment
  paymentTxHash        String           @db.VarChar(66)
  paymentChainId       Int              @default(1)
  feePaid              String           @default("0.05")
  // Market config
  tokenAddress         String           @db.VarChar(42)
  tokenSymbol          String
  tokenName            String
  quoteAsset           String           @default("USDT") // USDT | USDC
  chainId              Int              @default(1)
  oracleType           String           @default("chainlink") // chainlink | pyth | custom
  oracleAddress        String?          @db.VarChar(42)
  maxLeverage          Int              @default(100)
  tradingFeeBps        Int              @default(10) // basis points e.g. 10 = 0.1%
  liquidationFeeBps    Int              @default(100) // 100 = 1%
  initialMarginBps     Int              @default(100) // 100 = 1% (= 100x max leverage)
  maintenanceMarginBps Int              @default(50) // 50 = 0.5%
  maxOILong            String           @default("1000000") // USD string
  maxOIShort           String           @default("1000000")
  initialLiquidity     String           @default("0")
  description          String           @db.Text
  projectName          String
  projectUrl           String?
  logoUrl              String?
  // Admin workflow
  status               SubmissionStatus @default(PENDING)
  adminNote            String?          @db.Text
  reviewedBy           String?          @db.VarChar(42)
  reviewedAt           DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([submitterAddress])
  @@index([status])
}

// ── Token & LP Locks ──────────────────────────────────────────────────────────

model Lock {
  id           String    @id @default(cuid())
  lockType     String // token | lp
  onChainId    Int?
  tokenAddress String    @db.VarChar(42)
  tokenSymbol  String?
  token0Symbol String?
  token1Symbol String?
  amount       String // stored as string to handle bigint precision
  owner        String    @db.VarChar(42)
  unlockDate   DateTime
  txHash       String?   @db.VarChar(66)
  chainId      Int
  withdrawn    Boolean   @default(false)
  withdrawnAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  @@index([owner])
  @@index([tokenAddress])
  @@index([chainId, lockType])
}

// ── Pools (cached metadata) ───────────────────────────────────────────────────

model Pool {
  id           String   @id @default(cuid())
  address      String   @db.VarChar(42)
  chainId      Int
  token0       String   @db.VarChar(42)
  token1       String   @db.VarChar(42)
  token0Symbol String
  token1Symbol String
  feeTier      String   @default("0.3%")
  reserve0     String   @default("0")
  reserve1     String   @default("0")
  tvlUSD       Float    @default(0)
  volume24h    Float    @default(0)
  apr          Float    @default(0)
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@unique([address, chainId])
  @@index([chainId])
}

// ── Farms ─────────────────────────────────────────────────────────────────────

model Farm {
  id           String   @id @default(cuid())
  pid          Int
  chainId      Int
  name         String
  lpToken      String   @db.VarChar(42)
  token0Symbol String
  token1Symbol String
  rewardSymbol String
  aprPercent   Float    @default(0)
  tvlUSD       Float    @default(0)
  multiplier   String   @default("1x")
  active       Boolean  @default(true)
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@unique([pid, chainId])
}
